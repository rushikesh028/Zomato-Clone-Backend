PORT=8080

DB_URL=jdbc:mysql://localhost:3306/tastybuddy
DB_USERNAME=root
DB_PASSWORD=change-me
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
JPA_DIALECT=org.hibernate.dialect.MySQLDialect
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-and-never-commit-it
JWT_EXPIRATION_MS=3600000

RAZORPAY_KEY=rzp_test_your_key
RAZORPAY_SECRET=your_razorpay_secret

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
H2_CONSOLE_ENABLED=false
APP_SEED_DATA=true
APP_SEED_ADMIN_EMAIL=admin@tastybuddy.local
APP_SEED_ADMIN_PASSWORD=Admin@123
FLYWAY_BASELINE_ON_MIGRATE=true
